generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  resident
  staff
  healthworker
}


model system_setting {
  id              String  @id @default(uuid()) @db.Uuid
  logo_url        String
  web_name        String?
  web_color       String?
  barangay_status String?
  id_pattern      String?
}

model residents {
  id            String   @id @default(uuid()) @db.Uuid
  resident_id   String   @unique
  f_name        String
  m_name        String?
  l_name        String?
  s_name        String?
  purok         String?
  house_no      String?
  sex           String?
  b_date        String?
  b_place       String?
  voting_status String?
  sector        String?
  remarks       String?
  times_tamp    DateTime @default(now())
  email_address String?
  contact_no    String?

  complaints          complaints[]
  health_appointments health_appointments[]
  health_records      health_records[]
  notifications       notification[]
  transactions        transaction[]
  user                user?
}

model complaints {
  id             String   @id @default(uuid()) @db.Uuid
  resident_id    String @db.Uuid
  complaint_type String
  description    String
  filed_at       DateTime @default(now())
  status         String   @default("pending")
  image_paths    String?
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())

  resident residents @relation(fields: [resident_id], references: [id])
  blotters blotter[]
}

model blotter {
  id                      String   @id @default(uuid()) @db.Uuid
  complaint_id            String?  @db.Uuid  
  official_blotter_number String   @unique
  incident_date           DateTime @db.Date
  location                String?
  assigned_officer        String?
  remarks                 String?
  status                  String   @default("ongoing")
  image_paths             Json?
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now())

  complaint complaints? @relation(fields: [complaint_id], references: [id])
}

model certificates {
  id             String   @id @default(uuid()) @db.Uuid
  template_name  String
  template_price Float?
  template_path  String?
  timestamp      DateTime @default(now()) @db.Timestamp
  requestType    Boolean  @default(true)

  transactions transaction[]
}

model document_types {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?

  documents   documents[]
}

model documents {
  id                 String   @id @default(uuid()) @db.Uuid
  document_type_id   String   @db.Uuid
  title              String
  purpose            String?
  issued_date        DateTime? @db.Date
  expiration_date    DateTime? @db.Date
  status             String   @default("Active")
  file_url           String?
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())

  document_type document_types @relation(fields: [document_type_id], references: [id])
}

model health_appointments {
  id               String   @id @default(uuid()) @db.Uuid
  resident_id      String @db.Uuid
  blood_pressure   String
  appointment_date DateTime
  purpose          String?
  status           String   @default("pending")
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())

  resident residents @relation(fields: [resident_id], references: [id])
}

model health_records {
  id                 String   @id @default(uuid()) @db.Uuid
  resident_id        String @db.Uuid
  height_cm          Decimal?
  weight_kg          Decimal?
  blood_type         String?
  allergies          String?
  chronic_conditions String?
  last_checkup       DateTime? @db.Date
  vaccination_status Json?
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())

  resident   residents @relation(fields: [resident_id], references: [id])
  pregnancy  pregnancy_monitoring[]
}

model pregnancy_monitoring {
  id                     String   @id @default(uuid()) @db.Uuid
  health_record_id       String? @db.Uuid
  pregnancy_start_date   DateTime @db.Date
  expected_delivery_date DateTime @db.Date
  current_trimester      Int?
  complications          String?
  checkup_notes          String?
  last_checkup           DateTime? @db.Date
  status                 String   @default("ongoing")
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now())

  health_record health_records? @relation(fields: [health_record_id], references: [id])
}

model notification {
  id          String   @id @default(uuid()) @db.Uuid
  resident_id String @db.Uuid
  content     String?
  mark_read   Boolean @default(false)
  timestamp   DateTime? @db.Time

  resident residents @relation(fields: [resident_id], references: [id])
}

model transaction {
  id             String   @id @default(uuid()) @db.Uuid
  resident_id    String @db.Uuid
  certificate_id String @db.Uuid
  details        String
  status         String   @default("pending")
  timestamp      DateTime @default(now())

  resident    residents   @relation(fields: [resident_id], references: [id])
  certificate certificates @relation(fields: [certificate_id], references: [id])
}

model user {
  id          String   @id @default(uuid()) @db.Uuid
  resident_id String @db.Uuid @unique
  password    String?
  verified    Boolean @default(false)
  role        Role    @default(resident)

  resident residents @relation(fields: [resident_id], references: [id])
}